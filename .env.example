# Where finished video files land. Plex picks them up via its standard
# library scan; subdirectories per channel slug are created on demand.
OUTPUT_DIR=/mnt/storage/Media/Video/Clip

# Path to a Netscape-format cookies.txt — required for age-gated /
# member-only / region-locked YouTube videos. Leave unset for public
# content. Export from a logged-in browser via "Get cookies.txt LOCALLY"
# extension or `yt-dlp --cookies-from-browser`.
# COOKIES_FILE=/etc/yt-dlp-mcp/cookies.txt

# Override which yt-dlp binary the MCP invokes. Default is whatever's on
# $PATH; in production we point this at the venv copy so the daily
# update timer can bump it independently of any OS package.
# YT_DLP_BIN=/opt/yt-dlp-mcp/.venv/bin/yt-dlp

# SQLite-backed task store. Survives service restarts, so an in-flight
# download keeps reporting status to the bot's poller after a hiccup.
STATE_DB_PATH=.cache/yt_dlp_mcp.sqlite

# Bearer token for the streamable-HTTP transport. Required when the bot
# reaches us across the network (production); leave empty for stdio.
MCP_AUTH_TOKEN=

# Network listener. Default 127.0.0.1:8769 — only reachable from the
# media host. Bind to the hostname-routed interface in production if
# the bot lives on a separate box.
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8769
MCP_TRANSPORT=streamable-http

# Default playlist preview cap. Bigger values stay usable but the bot's
# inline keyboard tops out around 100 buttons regardless.
PLAYLIST_PREVIEW_LIMIT=20

# Recent finished tasks kept in SQLite. Doesn't affect on-disk video
# files; only the status entries the bot can poll.
TASK_HISTORY_KEEP=500
